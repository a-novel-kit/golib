{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "gomod": {
    "managerFilePatterns": ["/(^|/)go\\.mod$/", "/(^|/)golangci-lint\\.mod$/", "/(^|/)gotestsum\\.mod$/"]
  },
  "packageRules": [
    {
      "matchFileNames": ["go.mod"],
      "postUpdateOptions": ["gomodTidy"]
    },
    {
      "matchManagers": ["gomod"],
      "postUpgradeTasks": {
        "commands": [
          "go mod download",
          "go generate ./...",
          "go tool -modfile=golangci-lint.mod golangci-lint run ./... --fix"
        ],
        "executionMode": "branch"
      }
    },
    {
      "matchManagers": ["npm"],
      "postUpdateOptions": ["pnpmDedupe"],
      "postUpgradeTasks": {
        "commands": ["pnpm format"],
        "executionMode": "branch"
      }
    }
  ],
  "extends": ["config:recommended"]
}
