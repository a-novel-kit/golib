{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "postUpdateOptions": ["gomodTidy", "pnpmDedupe"],
  "packageRules": [
    {
      "matchCategories": ["golang"],
      "managerFilePatterns": [
        "/(^|/)go\\.mod$/",
        "/(^|/)golangci-lint\\.mod$/",
        "/(^|/)gotestsum\\.mod$/"
      ]
    },
    {
      "matchManagers": ["gomod"],
      "postUpgradeTasks": {
        "commands": [
          "go mod download",
          "go generate ./...",
          "go tool -modfile=golangci-lint.mod golangci-lint run ./... --fix"
        ],
        "executionMode": "branch"
      }
    },
    {
      "matchManagers": ["npm"],
      "postUpgradeTasks": {
        "commands": ["pnpm format"],
        "executionMode": "branch"
      }
    }
  ],
  "extends": ["config:recommended"]
}
