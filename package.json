{
  "name": "golib",
  "version": "0.22.7",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "format": "pnpm run format:prettier",
    "format:go": "go mod tidy && go tool -modfile=golangci-lint.mod golangci-lint run ./... --fix",
    "format:prettier": "prettier --write . --config prettier.config.js",
    "format:proto": "go tool buf format -w && go tool buf dep update",
    "generate": "pnpm run generate:go",
    "generate:go": "go generate ./...",
    "lint": "pnpm run lint:prettier",
    "lint:go": "go tool -modfile=golangci-lint.mod golangci-lint run ./...",
    "lint:prettier": "prettier --check . --config prettier.config.js",
    "lint:proto": "go tool buf lint",
    "publish:major": "a-novel publish version major",
    "publish:minor": "a-novel publish version minor",
    "publish:patch": "a-novel publish version patch"
  },
  "devDependencies": {
    "prettier": "^3.6.2",
    "prettier-plugin-packagejson": "^3.0.0"
  },
  "packageManager": "pnpm@11.5.2"
}
